          <div>
            <p class="text-zinc-400 font-medium mb-2"><span class="lang-en">By Role</span><span class="lang-zh">按角色</span></p>
            <div class="flex flex-col gap-1">
              <a href={`${base}/apply/investment-banking`}><span class="lang-en">Investment Banking</span><span class="lang-zh">投資銀行</span></a>
              <a href={`${base}/apply/asset-management`}><span class="lang-en">Asset Management</span><span class="lang-zh">資產管理</span></a>
              <a href={`${base}/apply/family-offices`}><span class="lang-en">Family Offices</span><span class="lang-zh">家族辦公室</span></a>
              <a href={`${base}/apply/prop-trading`}><span class="lang-en">Prop Trading</span><span class="lang-zh">自營交易</span></a>
              <a href={`${base}/apply/compliance`}><span class="lang-en">Compliance &amp; Risk</span><span class="lang-zh">合規與風險</span></a>
