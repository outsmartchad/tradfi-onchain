        <p class="text-[11px] text-zinc-600 uppercase tracking-wider mt-3 mb-1">
          <span class="lang-en">By Role</span><span class="lang-zh">按角色</span>
        </p>
        <a href={`${base}/apply/investment-banking`} class="py-2 pl-3 hover:text-white">
