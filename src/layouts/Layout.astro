---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A practical guide for Hong Kong finance professionals exploring onchain markets — prediction markets, perpetual exchanges, and automated market making.' } = Astro.props;
const base = '/tradfi-onchain';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | TradFi × Onchain</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen">
  <nav class="fixed top-0 w-full z-50 border-b border-zinc-800/50 bg-[#0a0a0f]/80 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href={`${base}/`} class="text-lg font-semibold tracking-tight text-white hover:opacity-100">
        TradFi<span class="text-cyan-400">×</span>Onchain
      </a>
      <div class="hidden md:flex items-center gap-7 text-sm text-zinc-400">
        <a href={`${base}/landscape`} class="hover:text-white transition-colors">
          <span class="lang-en">Landscape</span><span class="lang-zh">市場動態</span>
        </a>

        <!-- Products dropdown -->
        <div class="relative group">
          <button class="hover:text-white transition-colors flex items-center gap-1">
            <span class="lang-en">Products</span><span class="lang-zh">產品</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
