        <div class="flex gap-10 flex-wrap">
          <div>
            <p class="text-zinc-400 font-medium mb-2"><span class="lang-en">Products</span><span class="lang-zh">產品</span></p>
            <div class="flex flex-col gap-1">
              <a href={`${base}/products/polymarket`}>Polymarket</a>
              <a href={`${base}/products/hyperliquid`}>Hyperliquid</a>
              <a href={`${base}/products/amm`}><span class="lang-en">Onchain AMM</span><span class="lang-zh">鏈上AMM</span></a>
