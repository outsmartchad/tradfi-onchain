          <div class="absolute left-0 top-full pt-2 hidden group-hover:block">
            <div class="bg-[#0a0a0f] border border-zinc-800 rounded-lg py-2 min-w-[180px] shadow-xl">
              <a href={`${base}/products/polymarket`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">Polymarket</a>
              <a href={`${base}/products/hyperliquid`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">Hyperliquid</a>
              <a href={`${base}/products/amm`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">
                <span class="lang-en">Onchain AMM</span><span class="lang-zh">鏈上AMM</span>
              </a>
              <div class="border-t border-zinc-800/50 my-1"></div>
              <p class="px-4 py-1 text-[10px] text-zinc-600 uppercase tracking-wider"><span class="lang-en">Token Launch</span><span class="lang-zh">代幣發射</span></p>
              <a href={`${base}/products/amm/pumpfun`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">PumpFun</a>
              <a href={`${base}/products/amm/pumpswap`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">PumpSwap</a>
              <a href={`${base}/products/amm/raydium-launchlab`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">Raydium LaunchLab</a>
              <a href={`${base}/products/amm/meteora-dbc`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">Meteora DBC</a>
              <p class="px-4 py-1 text-[10px] text-zinc-600 uppercase tracking-wider">AMM</p>
              <a href={`${base}/products/amm/raydium-cpmm`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">Raydium CPMM</a>
              <a href={`${base}/products/amm/raydium-clmm`} class="block px-4 py-2 text-sm hover:bg-zinc-900 hover:text-white">Raydium CLMM</a>
